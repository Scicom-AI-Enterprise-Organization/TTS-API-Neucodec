TTS_API=http://localhost:9093
MODEL_NAME=TTS-model
DYNAMIC_BATCHING=true
CUDA_GRAPH_BATCH=[0.5,1.0,1.5,2.0,3.0,4.0]
TORCH_COMPILE=false
MAX_BATCH_SIZE=8
MICROSLEEP=1e-4
DEFAULT_SPEAKER=husein
SPEAKERS=husein,idayu,arissa,haiqal
DEFAULT_TEMPERATURE=0.6
DEFAULT_PLAYBACK_SPEED=1.5
DEFAULT_PLAYBACK_OVERLAP_SPEED=0.2
# Boundary-click ('snap') fix: crossfade adjacent decode chunks instead of hard-splicing.
STREAM_CROSSFADE=true
CROSSFADE_MS=12.0
HF_TOKEN=<your_hf_token>
HUGGING_FACE_HUB_TOKEN=<your_hf_token>
